// Defines the files that form part of this package for purposes of ESLint. Similar configs exist at the package level.
// Because `parseOptions.parser` is set to `"@typescript-eslint/parser"` in the ESLint config, ESLint can lint
// only the files listed under `include` below.
// If ESLint is asked to lint a file not targeted by the `include` patterns (e.g., `eslint --ext .js`)
// it will report an error:
//   Parsing error: "parserOptions.project" has been set for @typescript-eslint/parser.`
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true, // ensure that nobody can accidentally use this config for a build
  },
  // These files will be linted
  // prettier-ignore
  "include": [
    "./",
    "!packages/",
    "eslint.config.js",
    "*.json",
    "*.mjs",
    "*.ts",
  ],
}
