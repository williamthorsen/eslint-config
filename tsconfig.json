// TSConfig for monorepo root. Packages have their own tsconfig.json files that extend this one.
{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@williamthorsen/tsconfig/base.json",
  "compilerOptions": {
    // Modern transformation by React 17+
    "jsx": "react-jsx",
    // Cannot move to the base: `baseUrl`-less `paths` resolve relative to the declaring file.
    "paths": {
      "~/*": ["./*"],
    },
    // Restrict ambient types to Node's, rather than every @types package in scope.
    "types": ["node"],
  },
  // prettier-ignore
  "include": [
    ".config/**/*.ts",
    ".github/scripts/",
    "__tests__/",
    "config/",
    "scripts/",
    "*.ts",
  ],
}
