{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "7.0.0",
  "description": "ESLint config for TypeScript, JSON & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config/tree/main/packages/typescript#readme",
  "bugs": {
    "url": "https://github.com/williamthorsen/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamthorsen/eslint-config.git",
    "directory": "packages/typescript"
  },
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./configs": {
      "import": "./dist/esm/configs/index.js",
      "types": "./dist/esm/configs/index.d.ts"
    },
    "./ignores": {
      "import": "./dist/esm/ignores/index.js",
      "types": "./dist/esm/ignores/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/esm/plugins/index.js",
      "types": "./dist/esm/plugins/index.d.ts"
    },
    "./utils": {
      "import": "./dist/esm/utils/index.js",
      "types": "./dist/esm/utils/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "nmr build"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsonc": "3.3.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-package-json": "1.6.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "eslint-plugin-unicorn": "72.0.0",
    "eslint-plugin-yml": "3.6.0",
    "globals": "17.7.0",
    "jsonc-eslint-parser": "3.1.0",
    "typescript-eslint": "8.65.0",
    "yaml-eslint-parser": "2.1.0"
  },
  "devDependencies": {
    "@eslint/config-helpers": "0.6.0",
    "@next/eslint-plugin-next": "16.2.11",
    "@typescript-eslint/rule-tester": "8.65.0",
    "@typescript-eslint/utils": "8.65.0",
    "@vitest/eslint-plugin": "1.6.23",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-testing-library": "7.16.2"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8.59.1",
    "eslint": ">=10",
    "typescript": ">=5"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
