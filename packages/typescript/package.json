{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "5.11.0",
  "description": "ESLint config for TypeScript, JSON & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js",
    "./configs": "./dist/esm/configs/index.js",
    "./ignores": "./dist/esm/ignores/index.js",
    "./plugins": "./dist/esm/configs/index.js",
    "./utils": "./dist/esm/utils/index.js"
  },
  "files": [
    "dist/esm/index.js",
    "dist/esm/configs/*",
    "dist/esm/ignores/*",
    "dist/esm/plugins/*",
    "dist/esm/utils/*"
  ],
  "scripts": {
    "--ignore--preprepare": "pnpm run ws build",
    "publish:github": "GH_PACKAGES_TOKEN=$GITHUB_TOKEN pnpm publish",
    "publish:jsr": "npx jsr publish",
    "publish:jsr:dry-run": "npx jsr publish --dry-run",
    "rebuild": "pnpm run ws build",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsonc": "2.21.0",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "61.0.2",
    "eslint-plugin-yml": "1.19.0",
    "globals": "16.4.0",
    "jsonc-eslint-parser": "2.4.1",
    "typescript-eslint": "8.46.1",
    "yaml-eslint-parser": "1.3.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "15.5.6",
    "@typescript-eslint/utils": "8.46.1",
    "@vitest/eslint-plugin": "1.3.10",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-testing-library": "7.13.3"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
