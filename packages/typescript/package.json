{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "3.2.0",
  "description": "ESLint config for TypeScript, JSON & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js",
    "./configs": "./dist/esm/configs/index.js",
    "./ignores": "./dist/esm/ignores/index.js",
    "./utils": "./dist/esm/utils/index.js"
  },
  "files": [
    "dist/esm/index.js",
    "dist/esm/configs/*",
    "dist/esm/ignores/*",
    "dist/esm/utils/*",
    "dist/types/*"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --noEmit false",
    "check": "pnpm run lint:strict",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "../strict-lint/scripts/strict-lint.ts",
    "prepare": "pnpm run build",
    "publish:github": "pnpm publish",
    "publish:jsr": "npx jsr publish",
    "publish:jsr:dry-run": "npx jsr publish --dry-run",
    "rebuild": "tsc --noEmit false"
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsonc": "2.19.1",
    "eslint-plugin-n": "17.16.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "57.0.0",
    "eslint-plugin-yml": "1.17.0",
    "globals": "16.0.0",
    "jsonc-eslint-parser": "2.4.0",
    "yaml-eslint-parser": "1.3.0"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "eslint": "9.21.0",
    "typescript-eslint": "8.25.0"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript-eslint": ">=8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
