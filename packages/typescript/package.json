{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "0.15.1",
  "description": "Flat ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.mjs",
    "ignores/*",
    "rules/*",
    "utils/*"
  ],
  "scripts": {
    "check": "pnpm run lint:strict",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "../strict-lint/scripts/strict-lint.ts"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsonc": "^2.16.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.2.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unicorn": "^48.0.1",
    "eslint-plugin-yml": "^1.14.0",
    "jsonc-eslint-parser": "^2.4.0",
    "yaml-eslint-parser": "^1.2.3"
  },
  "devDependencies": {
    "@types/eslint": "^8.56.10",
    "eslint": "^8.57.0"
  },
  "peerDependencies": {
    "eslint": ">=8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
