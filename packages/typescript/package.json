{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "2.1.1",
  "description": "ESLint config for TypeScript, JSON & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": {
      "default": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs"
    },
    "./ignores": "./dist/esm/ignores/*",
    "./rules": "./dist/esm/rules/*"
  },
  "files": [
    "dist/esm/index.mjs",
    "dist/esm/ignores/*",
    "dist/esm/rules/*",
    "dist/esm/utils/*"
  ],
  "scripts": {
    "build": "tsc --noEmit false && mv dist/esm/index.js dist/esm/index.mjs",
    "check": "pnpm run lint:strict",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "../strict-lint/scripts/strict-lint.ts",
    "prepare": "pnpm run build",
    "publish:github": "pnpm publish",
    "publish:jsr": "npx jsr publish",
    "publish:jsr:dry-run": "npx jsr publish --dry-run"
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsonc": "2.16.0",
    "eslint-plugin-n": "17.12.0",
    "eslint-plugin-promise": "7.1.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "56.0.0",
    "eslint-plugin-yml": "1.15.0",
    "globals": "15.11.0",
    "jsonc-eslint-parser": "2.4.0",
    "yaml-eslint-parser": "1.2.3"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "eslint": "9.14.0",
    "typescript-eslint": "8.12.2"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript-eslint": ">=8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
