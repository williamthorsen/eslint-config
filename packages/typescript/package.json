{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "5.1.0",
  "description": "ESLint config for TypeScript, JSON & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js",
    "./configs": "./dist/esm/configs/index.js",
    "./ignores": "./dist/esm/ignores/index.js",
    "./plugins": "./dist/esm/configs/index.js",
    "./utils": "./dist/esm/utils/index.js"
  },
  "files": [
    "dist/esm/index.js",
    "dist/esm/configs/*",
    "dist/esm/ignores/*",
    "dist/esm/plugins/*",
    "dist/esm/utils/*",
    "dist/types/*"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --noEmit false",
    "prepare": "pnpm run build",
    "publish:github": "pnpm publish",
    "publish:jsr": "npx jsr publish",
    "publish:jsr:dry-run": "npx jsr publish --dry-run",
    "rebuild": "tsc --noEmit false",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsonc": "2.20.0",
    "eslint-plugin-n": "17.17.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "59.0.0",
    "eslint-plugin-yml": "1.18.0",
    "globals": "16.0.0",
    "jsonc-eslint-parser": "2.4.0",
    "typescript-eslint": "8.31.1",
    "yaml-eslint-parser": "1.3.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "15.3.1",
    "@types/eslint": "9.6.1",
    "@typescript-eslint/utils": "8.31.1",
    "@vitest/eslint-plugin": "1.1.43",
    "eslint": "9.25.1",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-testing-library": "7.1.1"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
