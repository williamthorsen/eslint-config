{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "5.14.0",
  "description": "ESLint config for TypeScript, JSON & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js",
    "./configs": "./dist/esm/configs/index.js",
    "./ignores": "./dist/esm/ignores/index.js",
    "./plugins": "./dist/esm/configs/index.js",
    "./utils": "./dist/esm/utils/index.js"
  },
  "files": [
    "dist/esm/index.js",
    "dist/esm/configs/*",
    "dist/esm/ignores/*",
    "dist/esm/plugins/*",
    "dist/esm/utils/*"
  ],
  "scripts": {
    "build": "pnpm run ws clean && pnpm run ws compile && pnpm run ws generate-typings",
    "prepublishOnly": "pnpm run build",
    "publish:github": "GH_PACKAGES_TOKEN=$GITHUB_TOKEN pnpm publish",
    "publish:jsr": "npx jsr publish",
    "publish:jsr:dry-run": "npx jsr publish --dry-run",
    "test": "echo 'No tests defined for typescript package.'",
    "test:coverage": "echo 'No tests defined for typescript package.'",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsonc": "3.1.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-package-json": "0.89.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-plugin-yml": "3.3.1",
    "globals": "17.4.0",
    "jsonc-eslint-parser": "3.1.0",
    "typescript-eslint": "8.56.1",
    "yaml-eslint-parser": "2.0.0"
  },
  "devDependencies": {
    "@eslint/config-helpers": "0.5.3",
    "@next/eslint-plugin-next": "16.1.6",
    "@typescript-eslint/utils": "8.56.1",
    "@vitest/eslint-plugin": "1.6.9",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-testing-library": "7.16.0"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript": ">=5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
