{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "0.10.5",
  "description": "Flat ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.mjs",
    "ignores/*",
    "rules/*"
  ],
  "scripts": {
    "audit": "pnpm run audit:prod && pnpm run audit:dev",
    "audit:dev": "pnpm audit --dev",
    "audit:prod": "pnpm audit --audit-level=high --prod",
    "check": "pnpm run lint && pnpm run audit",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix ."
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "@typescript-eslint/parser": "^5.52.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsonc": "^2.6.0",
    "eslint-plugin-markdown": "^3.0.0",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unicorn": "^45.0.2",
    "eslint-plugin-yml": "^1.5.0",
    "jsonc-eslint-parser": "^2.1.0",
    "yaml-eslint-parser": "^1.1.0"
  },
  "devDependencies": {
    "@types/eslint": "^8.21.1",
    "eslint": "^8.34.0"
  },
  "peerDependencies": {
    "eslint": ">=8",
    "typescript": ">=3.9"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
