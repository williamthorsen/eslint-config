{
  "name": "@williamthorsen/eslint-config-typescript",
  "version": "1.0.0",
  "description": "Flat ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.js",
    "ignores/*",
    "rules/*",
    "utils/*"
  ],
  "scripts": {
    "build": "tsc --noEmit false",
    "check": "pnpm run lint:strict",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "../strict-lint/scripts/strict-lint.ts",
    "publish:github": "pnpm publish",
    "publish:jsr": "npx jsr publish",
    "publish:jsr:dry-run": "npx jsr publish --dry-run"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "8.8.1",
    "@typescript-eslint/parser": "8.8.1",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsonc": "2.16.0",
    "eslint-plugin-n": "17.11.1",
    "eslint-plugin-promise": "7.1.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "56.0.0",
    "eslint-plugin-yml": "1.14.0",
    "globals": "15.11.0",
    "jsonc-eslint-parser": "2.4.0",
    "yaml-eslint-parser": "1.2.3"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "eslint": "9.12.0",
    "typescript-eslint": "8.12.2"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "typescript-eslint": ">=8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
