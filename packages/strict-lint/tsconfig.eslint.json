// For an explanation of this file's purpose, see the file of the same name in the monorepo root.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true, // ensure that nobody can accidentally use this config for a build
  },
  "include": [
    "src/",
    // These patterns include files not reachable from `src/index.ts`
    "scripts/",
    "eslint.config.js",
    "*.json",
    "*.ts",
  ],
}
