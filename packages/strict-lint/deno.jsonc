/* @link https://deno.com/manual/getting_started/configuration_file */
{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "fmt": {
    "exclude": [
      "**/dist",
      "**/node_modules/",
      "**/*.json"
    ],
    "lineWidth": 120,
    "proseWrap": "preserve",
    "singleQuote": true
  },
  "lint": {
    "exclude": [
      "**/dist",
      "**/node_modules/",
      "**/*.json"
    ]
  },
  "name": "@williamthorsen/strict-lint",
  "version": "3.0.0",
  "description": "Strict linting for ESLint projects",
  "license": "UNLICENSED",
  "exports": {
    ".": "./index.ts"
  },
  "publish": {
    "include": [
      "index.ts",
      "README.md",
      "ignores/*",
      "rules/*",
      "utils/*"
    ]
  }
}
