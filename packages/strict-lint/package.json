{
  "name": "@williamthorsen/strict-lint",
  "version": "5.3.0",
  "description": "Strict linting for ESLint projects",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "strict-lint": "./dist/bin/strict-lint.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm tsc --build tsconfig.build.json && mv dist/scripts dist/bin && tsx scripts/replace-shebang.ts && rimraf dist/bin/*.d.ts",
    "clean": "pnpm rimraf dist/*",
    "lint:strict": "tsx scripts/strict-lint.ts",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "tsx": "4.19.4"
  },
  "devDependencies": {
    "eslint": "9.27.0",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
