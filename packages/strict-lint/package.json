{
  "name": "@williamthorsen/strict-lint",
  "version": "3.2.0",
  "description": "Strict linting for ESLint projects",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "strict-lint": "./dist/bin/strict-lint.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm tsc --build tsconfig.build.json && mv dist/scripts dist/bin && tsx scripts/replace-shebang.ts && rimraf dist/bin/*.d.ts",
    "check": "pnpm run typecheck && pnpm run lint:strict && pnpm test:coverage",
    "clean": "pnpm rimraf dist/*",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "tsx scripts/strict-lint.ts",
    "test": "pnpm vitest",
    "test:coverage": "pnpm vitest --coverage",
    "test:watch": "pnpm vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tsx": "4.19.3"
  },
  "devDependencies": {
    "eslint": "9.21.0",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
