{
  "name": "@williamthorsen/strict-lint",
  "version": "5.3.2",
  "description": "Strict linting for ESLint projects",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./dist/esm/index.js"
  },
  "bin": {
    "strict-lint": "./dist/bin/strict-lint.js"
  },
  "files": [
    "dist/esm/index.js"
  ],
  "scripts": {
    "build": "pnpm run ws clean && pnpm run ws compile && pnpm run ws generate-typings && mv dist/esm/scripts dist/bin && tsx scripts/replace-shebang.ts && rimraf dist/bin/*.d.ts",
    "clean": "pnpm rimraf dist/*",
    "lint:strict": "tsx scripts/strict-lint.ts",
    "ws": "node --import tsx ../../scripts/run-workspace-script.ts"
  },
  "dependencies": {
    "tsx": "4.20.6"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
