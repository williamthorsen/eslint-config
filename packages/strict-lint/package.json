{
  "name": "strict-lint",
  "version": "0.10.11",
  "description": "Strict linting for ESLint projects",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "check": "pnpm run typecheck && pnpm run lint && pnpm test:coverage",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "test": "pnpm vitest",
    "test:coverage": "pnpm vitest --coverage",
    "test:watch": "pnpm vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.1.6"
  }
}
