{
  "name": "@williamthorsen/eslint-config-basic",
  "version": "5.11.7",
  "description": "ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.mjs",
    "jsPlugins.mjs",
    "ignores/*",
    "rules/*",
    "utils/*"
  ],
  "scripts": {
    "check": "pnpm run lint:strict",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "../strict-lint/scripts/strict-lint.ts",
    "test": "echo 'No tests defined for basic package.'",
    "test:coverage": "echo 'No tests defined for basic package.'"
  },
  "dependencies": {
    "@eslint/markdown": "7.5.1",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-html": "8.1.4",
    "eslint-plugin-jsonc": "3.1.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-package-json": "0.90.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-plugin-yml": "3.3.1",
    "jsonc-eslint-parser": "3.1.0",
    "yaml-eslint-parser": "2.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
