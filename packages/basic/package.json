{
  "name": "@williamthorsen/eslint-config-basic",
  "version": "0.10.7",
  "description": "ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.mjs",
    "jsPlugins.mjs",
    "ignores/*",
    "rules/*"
  ],
  "scripts": {
    "audit": "pnpm run audit:prod && pnpm run audit:dev",
    "audit:dev": "pnpm audit --dev",
    "audit:prod": "pnpm audit --audit-level=high --prod",
    "check": "pnpm run lint && pnpm run audit",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix ."
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-html": "^7.1.0",
    "eslint-plugin-jsonc": "^2.8.0",
    "eslint-plugin-markdown": "^3.0.0",
    "eslint-plugin-n": "^16.0.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unicorn": "^47.0.0",
    "eslint-plugin-yml": "^1.7.0",
    "jsonc-eslint-parser": "^2.3.0",
    "yaml-eslint-parser": "^1.2.2"
  },
  "devDependencies": {
    "eslint": "^8.41.0"
  },
  "peerDependencies": {
    "eslint": ">=8"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
