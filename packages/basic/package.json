{
  "name": "@williamthorsen/eslint-config-basic",
  "version": "5.11.11",
  "private": true,
  "description": "ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config/tree/main/packages/basic#readme",
  "bugs": {
    "url": "https://github.com/williamthorsen/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamthorsen/eslint-config.git",
    "directory": "packages/basic"
  },
  "license": "ISC",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.mjs",
    "jsPlugins.mjs",
    "ignores/*",
    "rules/*",
    "utils/*"
  ],
  "scripts": {
    "build": ":",
    "check": "nmr lint:strict",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "test": ":",
    "test:coverage": ":"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/markdown": "8.0.3",
    "eslint-plugin-html": "8.1.4",
    "eslint-plugin-jsonc": "3.3.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "72.0.0",
    "eslint-plugin-yml": "3.6.0",
    "jsonc-eslint-parser": "3.1.0",
    "yaml-eslint-parser": "2.1.0"
  },
  "peerDependencies": {
    "eslint": ">=10"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  }
}
