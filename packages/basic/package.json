{
  "name": "@williamthorsen/eslint-config-basic",
  "version": "3.2.1",
  "description": "ESLint config for TypeScript, JSON, Markdown & YML",
  "keywords": [
    "eslint-config"
  ],
  "homepage": "https://github.com/williamthorsen/eslint-config",
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "exports": {
    ".": "./index.mjs",
    "./ignores": "./ignores/*",
    "./rules": "./rules/*"
  },
  "files": [
    "index.mjs",
    "jsPlugins.mjs",
    "ignores/*",
    "rules/*",
    "utils/*"
  ],
  "scripts": {
    "check": "pnpm run lint:strict",
    "lint": "pnpm eslint .",
    "lint:fix": "pnpm eslint --fix .",
    "lint:strict": "../strict-lint/scripts/strict-lint.ts"
  },
  "dependencies": {
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-html": "8.1.2",
    "eslint-plugin-jsonc": "2.19.1",
    "eslint-plugin-markdown": "5.1.0",
    "eslint-plugin-n": "17.16.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "57.0.0",
    "eslint-plugin-yml": "1.17.0",
    "jsonc-eslint-parser": "2.4.0",
    "yaml-eslint-parser": "1.3.0"
  },
  "devDependencies": {
    "eslint": "9.21.0"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
