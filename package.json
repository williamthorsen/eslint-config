{
  "name": "@williamthorsen/eslint-config-monorepo",
  "version": "5.9.0",
  "private": true,
  "description": "ESLint configs monorepo",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "scripts": {
    "audit": "pnpm run audit:prod && pnpm run audit:dev",
    "audit:dev": "pnpm dlx audit-ci@^6 --config .audit-ci/config.dev.json5",
    "audit:prod": "pnpm dlx audit-ci@^6 --config .audit-ci/config.prod.json5",
    "build": "pnpm --recursive run build",
    "ci": "pnpm run check:strict && pnpm run build",
    "check": "pnpm run typecheck && pnpm run fmt:check && pnpm run lint:check && pnpm run test",
    "check:strict": "pnpm run typecheck && pnpm run fmt:check && pnpm run lint:strict && pnpm run test:coverage && pnpm run audit",
    "fmt": "prettier --list-different --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "lint:strict": "tsx packages/strict-lint/scripts/strict-lint.ts",
    "outdated": "pnpm outdated --compatible --recursive",
    "outdated:latest": "pnpm outdated --recursive",
    "rebuild": "pnpm --prefix packages/typescript run rebuild",
    "root:test": "vitest --config ./vitest.root.config.ts",
    "test": "pnpm run root:test",
    "test:coverage": "pnpm --recursive run ws test:coverage",
    "typecheck": "tsc --noEmit",
    "update": "pnpm update --recursive",
    "update:latest": "pnpm update --latest --recursive"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.5",
    "@eslint/js": "9.31.0",
    "@types/eslint": "9.6.1",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.15.34",
    "@vitest/coverage-v8": "3.2.4",
    "@williamthorsen/toolbelt.objects": "3.1.0",
    "esbuild": "0.25.7",
    "eslint": "9.31.0",
    "eslint-plugin-n": "17.21.0",
    "glob": "11.0.3",
    "globals": "16.3.0",
    "js-yaml": "4.1.0",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0",
    "vite": "7.0.5",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=18"
  }
}
