{
  "name": "@williamthorsen/eslint-config-monorepo",
  "version": "0.17.0",
  "private": true,
  "description": "ESLint configs monorepo",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "scripts": {
    "audit": "pnpm run audit:prod && pnpm run audit:dev",
    "audit:dev": "pnpm dlx audit-ci@^6 --config .audit-ci/config.dev.json5",
    "audit:prod": "pnpm dlx audit-ci@^6 --config .audit-ci/config.prod.json5",
    "check": "pnpm run typecheck && pnpm run lint:strict && pnpm run audit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:strict": "packages/strict-lint/scripts/strict-lint.ts",
    "outdated": "pnpm outdated --compatible --recursive",
    "outdated:latest": "pnpm outdated --recursive",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "update": "pnpm update --recursive",
    "update:latest": "pnpm update --latest --recursive"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@esbuild-kit/esm-loader": "^2.6.5",
    "@types/node": "^22.5.5",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.11.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "packageManager": "pnpm@9.11.0"
}
