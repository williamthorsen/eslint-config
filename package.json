{
  "name": "@williamthorsen/eslint-config-monorepo",
  "version": "3.1.1",
  "private": true,
  "description": "ESLint configs monorepo",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "William Thorsen <william@thorsen.dev> (https://github.com/williamthorsen)",
  "type": "module",
  "scripts": {
    "audit": "pnpm run audit:prod && pnpm run audit:dev",
    "audit:dev": "pnpm dlx audit-ci@^6 --config .audit-ci/config.dev.json5",
    "audit:prod": "pnpm dlx audit-ci@^6 --config .audit-ci/config.prod.json5",
    "build": "pnpm --recursive run build",
    "check": "pnpm run typecheck && pnpm run lint:strict && pnpm run audit",
    "lint": "eslint .",
    "lint:fix": "deno fmt && eslint --fix .",
    "lint:strict": "deno fmt --check && pnpm exec tsx packages/strict-lint/scripts/strict-lint.ts",
    "outdated": "pnpm outdated --compatible --recursive",
    "outdated:latest": "pnpm outdated --recursive",
    "rebuild": "pnpm --prefix packages/typescript run rebuild",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "update": "pnpm update --recursive",
    "update:latest": "pnpm update --latest --recursive"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.11",
    "@eslint/js": "9.17.0",
    "@types/node": "20.17.11",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "eslint-plugin-n": "17.15.1",
    "globals": "15.14.0",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.19.0",
    "vitest": "2.1.8"
  },
  "packageManager": "pnpm@9.15.5"
}
