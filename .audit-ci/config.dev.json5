{
  "$schema": "https://github.com/IBM/audit-ci/raw/main/docs/schema.json",
  "moderate": true,
  "allowlist": [
    // esbuild enables any website to send any requests to the development server and read the response
    // https://github.com/advisories/GHSA-67mh-4wv8-2f99
    // "GHSA-67mh-4wv8-2f99",

    // minimatch ReDoS via repeated wildcards (transitive: eslint → @eslint/config-array → minimatch)
    // Blocked until ESLint 10, which moves to minimatch ^10.2.1
    // https://github.com/advisories/GHSA-3ppc-4f35-3m26
    "GHSA-3ppc-4f35-3m26",
    // https://github.com/advisories/GHSA-7r86-cg39-jmmj
    "GHSA-7r86-cg39-jmmj",
    // https://github.com/advisories/GHSA-23c5-xmqv-rm74
    "GHSA-23c5-xmqv-rm74",

    // rollup arbitrary file write via path traversal (transitive: vite → rollup)
    // Patched in >=4.59.0; vite allows ^4.43.0 but pnpm lockfile pins 4.46.2
    // https://github.com/advisories/GHSA-mw96-cpmx-2vgc
    "GHSA-mw96-cpmx-2vgc",

    // ajv ReDoS when using $data option (transitive: eslint → @eslint/eslintrc → ajv)
    // Patched in >=6.14.0; eslintrc allows ^6.12.4 but pnpm lockfile pins 6.12.6
    // https://github.com/advisories/GHSA-2g4f-4pwh-qvx6
    "GHSA-2g4f-4pwh-qvx6",

    // js-yaml prototype pollution in merge (transitive: @changesets/cli → @manypkg/get-packages → read-yaml-file → js-yaml)
    // Patched in >=3.14.2; read-yaml-file allows ^3.13.0 but pnpm lockfile pins 3.14.1
    // https://github.com/advisories/GHSA-mh29-5h37-fv8m
    "GHSA-mh29-5h37-fv8m",
  ],
  "extra-args": ["--dev"],
  "report-type": "summary",
}
